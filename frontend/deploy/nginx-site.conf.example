# Example Nginx server block for this static site (contents of `dist/`).
#
# 1. Copy to e.g. /etc/nginx/sites-available/portfolio && symlink sites-enabled.
# 2. Replace YOUR_DOMAIN, paths to `dist/`, and SSL cert paths (after certbot).
# 3. `sudo nginx -t && sudo systemctl reload nginx`

# Redirect HTTP → HTTPS (after certificates exist)
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;
    return 301 https://YOUR_DOMAIN$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN;

    # Let's Encrypt (Certbot) — typical paths:
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Absolute path on the VPS to the deployed `dist/` folder (only this dir is the docroot)
    root /var/www/portfolio/dist;
    index index.html;

    charset utf-8;

    # Security headers (tune as needed)
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~* \.(css|js|svg|pdf|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800, must-revalidate";
    }

    # Optional: deny access to hidden files
    location ~ /\. {
        deny all;
    }
}
