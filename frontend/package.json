{
  "name": "rohit-portfolio-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Static portfolio site (HTML, SCSS, vanilla JS)",
  "scripts": {
    "build": "npm run build:css && node scripts/build-dist.js",
    "build:prod": "sass --no-source-map --style=compressed assets/scss/main.scss css/main.css && node scripts/build-dist.js",
    "build:css": "sass --no-source-map assets/scss/main.scss css/main.css",
    "build:dist": "node scripts/build-dist.js",
    "watch:css": "sass --watch assets/scss/main.scss:css/main.css",
    "dev": "concurrently -k -n scss,site -c cyan,magenta \"npm run watch:css\" \"serve . -p 3000\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sass": "^1.86.0",
    "serve": "^14.2.4"
  }
}
